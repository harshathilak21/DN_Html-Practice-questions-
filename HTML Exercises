8. Local Storage
<select id="event">
    <option>Sports</option>
    <option>Music</option>
</select>

<script>
localStorage.setItem("event","Sports");

let e = localStorage.getItem("event");
document.getElementById("event").value = e;

function clearData(){
    localStorage.clear();
    sessionStorage.clear();
}
</script>

<button onclick="clearData()">Clear Preferences</button>

9. Geolocation
<button onclick="findLocation()">
    Find Nearby Events
</button>

<script>
function findLocation(){
    navigator.geolocation.getCurrentPosition(
        function(pos){
            alert(pos.coords.latitude +
                  "," +
                  pos.coords.longitude);
        },
        function(){
            alert("Permission Denied");
        },
        {enableHighAccuracy:true}
    );
}
</script>
