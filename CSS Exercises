5. Typography
  html
  <link href="https://fonts.googleapis.com/css2?family=Roboto&display=swap" rel="stylesheet">
  css
  body{
    font-family:'Roboto',sans-serif;
    font-size:18px;
}

p{
    font-style:italic;
    font-weight:bold;
    text-align:center;
    text-transform:uppercase;
    letter-spacing:2px;
    line-height:30px;
}

6. Link and List Styling
a:link{
    color:blue;
}

a:hover{
    color:red;
}

a:active{
    color:green;
}

a:visited{
    color:purple;
}

ul{
    list-style-type:none;
}

li{
    padding:10px;
    margin:5px;
}

7. Table Styling
table{
    border-collapse:collapse;
    width:100%;
}

th,td{
    border:1px solid black;
    padding:10px;
    text-align:center;
}

tr:nth-child(even){
    background-color:lightgray;
}

8. Box Model
.eventCard{
    border:2px solid black;
    padding:20px;
    margin:15px;
}

input:focus{
    outline:2px solid red;
}

.hidden{
    visibility:hidden;
}

.none{
    display:none;
}

9. Multiple Columns
.article{
    column-count:2;
    column-gap:30px;
    column-rule:1px solid gray;
}

10. Responsive Web Design
@media screen and (max-width:768px){

nav a{
    display:block;
}

img{
    width:80%;
}

body{
    font-size:14px;
}
}
